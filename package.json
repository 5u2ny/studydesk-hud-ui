{
  "name": "focus-os",
  "version": "2.0.0",
  "description": "Local-first academic command center for students — courses, deadlines, capture, study, and critical alerts",
  "main": "dist/main/main/index.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "postinstall": "echo 'no native rebuild needed'",
    "dist:mac": "npm run build && electron-builder --mac --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:renderer": "vite",
    "test": "vitest run"
  },
  "author": "Sunny Soni",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.10",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.5.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.sunnysoni.focusos",
    "productName": "Focus OS",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dir",
      "icon": null
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main/main/index.js"
    }
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tiptap/core": "^2.6.0",
    "@tiptap/extension-underline": "^2.6.0",
    "@tiptap/react": "^2.6.0",
    "@tiptap/starter-kit": "^2.6.0",
    "active-win": "^7.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "imapflow": "^1.3.2",
    "lucide-react": "^1.11.0",
    "mailparser": "^3.7.1",
    "node-addon-api": "^8.7.0",
    "pdfjs-dist": "^4.0.379",
    "tailwind-merge": "^3.5.0",
    "uiohook-napi": "^1.5.5"
  }
}
